# ─── Database Configuration ──────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://ujang@localhost:5432/wedding_db?schema=public"

# ─── Authentication (NextAuth.js) ─────────────────────────────────────────────
# Generate a secret key using: openssl rand -base64 32
AUTH_SECRET="your-generated-secret-here"
NEXTAUTH_SECRET="your-generated-secret-here"

# The base URL of your application
NEXTAUTH_URL="http://localhost:4123"

# ─── Email Service (Nodemailer via Gmail) ─────────────────────────────────────
# Used for sending verification OTP and password reset codes.
# Create an App Password here: https://myaccount.google.com/apppasswords
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"