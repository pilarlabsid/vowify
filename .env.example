# Database (PostgreSQL)
# Format: postgresql://USER@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://USER@localhost:5432/wedding_db?schema=public"

# NextAuth
# Generate dengan: openssl rand -base64 32
AUTH_SECRET="generate-dengan-openssl-rand-base64-32"
NEXTAUTH_SECRET="generate-dengan-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:4123"

# Gmail SMTP (untuk kirim OTP verifikasi email)
# Ganti dengan Gmail Anda dan App Password-nya
# Cara buat App Password: https://myaccount.google.com/apppasswords
GMAIL_USER="emailanda@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
